FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    build-essential g++ make git \
    clang-tidy clang-format \
    libgtest-dev cmake \
    openjdk-17-jre-headless \
    openssh-server sudo \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /usr/local/include /usr/local/lib && \
    cp -r /usr/include/gtest /usr/local/include/ && \
    ln -sf /usr/lib/$(uname -m)-linux-gnu/libgtest*.a /usr/local/lib/

RUN useradd -m -s /bin/bash jenkins && \
    echo "jenkins:jenkins" | chpasswd && \
    mkdir -p /home/jenkins/workspace /var/run/sshd && \
    chown -R jenkins:jenkins /home/jenkins

RUN sed -i 's/#PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config

EXPOSE 22
CMD ["/usr/sbin/sshd", "-D"]
